# ============================================================
# EQURIA Workspace — 환경변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# .env.local 은 git에 커밋하지 않습니다.
# ============================================================

# Anthropic (서버사이드 전용 — 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # 서버사이드 전용

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=이큐리아 워크스페이스

# 워크스페이스 공용 비밀번호 (이름 + 이 비번으로 로그인)
# 배포 환경에서는 반드시 강력한 값(12자 이상, 영문+숫자+특수문자)으로 설정
WORKSPACE_PASSWORD=changeme

# Google OAuth (Gmail·Drive 연동 — 모두 서버 전용, NEXT_PUBLIC_ 금지)
# Google Cloud Console → OAuth 클라이언트(웹 애플리케이션)에서 발급
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 승인된 리디렉션 URI와 정확히 일치해야 함(스킴/포트/경로/슬래시)
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/callback
# 토큰 암호화 키(AES-256-GCM) — 32바이트 base64. 생성: openssl rand -base64 32
# ⚠️ 분실 시 전 직원 Google 재연결 필요
GOOGLE_TOKEN_ENC_KEY=
