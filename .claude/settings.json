{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pre-push-gate.sh\"",
            "if": "Bash(git push*)",
            "timeout": 180,
            "statusMessage": "배포 게이트(tsc·lint) 검증 중…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/stop-verify.sh\"",
            "timeout": 120,
            "statusMessage": "자동 검증(tsc) 중…"
          }
        ]
      }
    ]
  }
}
